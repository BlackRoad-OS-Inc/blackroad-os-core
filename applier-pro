def run_command(script_name: str, args: list):
    """Run a sub-command."""
    script_path = Path(__file__).parent / f"{script_name}.py"

    if not script_path.exists():
        print(f"{ORANGE}❌ Error: {script_name}.py not found{END}")
        return 1

    cmd = ["python3", str(script_path)] + args
    return subprocess.call(cmd)


def main():
    """Main CLI entry point."""
    if len(sys.argv) < 2:
        print_help()
        return 0

    command = sys.argv[1]
    args = sys.argv[2:]

    # Command routing
    command_map = {
        # Core features
        "cover": "applier-cover-letter-ai",
        "batch": "applier-batch",
        "interview": "applier-interview-prep",
        "salary": "applier-salary-negotiator",
        "research": "applier-company-research",

        # Advanced features
        "platforms": "applier-advanced-platforms",
        "network": "applier-network-ai",
        "brand": "applier-brand-builder",
        "market": "applier-market-intelligence",

        # A-Z Complete System (NEW)
        "workday": "applier-workday-automation",
        "gmail": "applier-gmail-integration",
        "offers": "applier-offer-comparison",

        # Productivity & Organization
        "followup": "applier-follow-up-automation",
        "calendar": "applier-calendar-integration",
        "linkedin": "applier-linkedin-easy-apply",

        # Analytics & tracking
        "stats": "applier-analytics",
        "list": "applier-cli",
        "search": "applier-cli",
    }

    if command in ["help", "--help", "-h"]:
        print_help()
        return 0

    if command in command_map:
        return run_command(command_map[command], args)
    else:
        print(f"{ORANGE}❌ Unknown command: {command}{END}\n")
        print(f"Run '{BOLD}applier-pro help{END}' for usage information")
        return 1


if __name__ == "__main__":
    sys.exit(main())
