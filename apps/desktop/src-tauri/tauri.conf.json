{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlackRoad Core Desktop",
  "version": "0.0.1",
  "identifier": "com.blackroad.core",
  "build": {
    "beforeBuildCommand": "pnpm turbo run build --filter=@blackroad/web",
    "beforeDevCommand": "pnpm dev --filter=@blackroad/web",
    "frontendDist": "../web/.next",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "BlackRoad OS Core",
        "width": 1200,
        "height": 800
      }
    ]
  }
}
