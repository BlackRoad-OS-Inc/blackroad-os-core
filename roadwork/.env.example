# Environment
ENVIRONMENT=production

# URLs
API_URL=https://roadwork-production.up.railway.app
FRONTEND_URL=https://roadwork.blackroad.io

# Database (Railway auto-sets this)
DATABASE_URL=postgresql://user:password@host:5432/roadwork

# Redis (Railway auto-sets this)
REDIS_URL=redis://localhost:6379/0

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Gmail API
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://roadwork.blackroad.io/auth/google/callback

# SendGrid
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@blackroad.io

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption
FERNET_KEY=your-fernet-key-for-password-encryption

# URLs
API_URL=https://api-roadwork.blackroad.io
FRONTEND_URL=https://roadwork.blackroad.io

# Sentry
SENTRY_DSN=https://...@sentry.io/...

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60

# Application Limits
FREE_TIER_DAILY_LIMIT=10
PRO_TIER_DAILY_LIMIT=100
PREMIUM_TIER_DAILY_LIMIT=1000
