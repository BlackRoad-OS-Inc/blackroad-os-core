# BlackRoad OS Core - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SERVER
# =============================================================================
PORT=8080

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/blackroad_os"

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================
# Personal Access Token or GitHub App token
# Required scopes: repo, read:org
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=""

# Optional: For GitHub Enterprise Server
# GITHUB_API_URL="https://github.mycompany.com/api/v3"

# =============================================================================
# CLOUDFLARE INTEGRATION
# =============================================================================
# API Token with Zone:Read, DNS:Read permissions
# Get one at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=""

# Account ID (required for Tunnels/Pages)
# Find it in your Cloudflare dashboard URL or overview page
CLOUDFLARE_ACCOUNT_ID=""

# =============================================================================
# RAILWAY INTEGRATION
# =============================================================================
# API Token from Railway dashboard
# Get one at: https://railway.app/account/tokens
RAILWAY_TOKEN=""

# =============================================================================
# OPTIONAL: APPLICATION CONFIG
# =============================================================================
# NODE_ENV=development
# LOG_LEVEL=debug
