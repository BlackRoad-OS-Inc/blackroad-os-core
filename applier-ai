        elif 'APPLY' in recommendation:
            rec_emoji = "🟡"
        elif 'CONSIDER' in recommendation:
            rec_emoji = "🟠"
        else:
            rec_emoji = "🔴"

        print(f"\n{'='*70}")
        print(f"[{i}/{len(jobs)}] {job['title']} at {job['company']}")
        print(f"{'='*70}")
        print(f"URL: {job['url']}")
        print(f"\n🤖 AI Analysis:")
        print(f"  Match Score: {score:.1f}/100")
        print(f"  Success Rate: {success:.0f}%")
        print(f"  {rec_emoji} {recommendation}")

        if ai_match.get('reasons'):
            print(f"\n  Reasons:")
            for reason in ai_match['reasons']:
                print(f"    ✓ {reason}")

        if ai_match.get('warnings'):
            print(f"\n  Warnings:")
