    resume = RESUME_FILE.read_text() if RESUME_FILE.exists() else ""
    profile = load_profile()

    print(f"📋 Found {len(jobs)} AI-ranked jobs\n")

    applied = 0
    history = load_history()

    for i, job in enumerate(jobs, 1):
        ai_match = job.get('ai_match', {})
        score = ai_match.get('score', 0)
        success = ai_match.get('success_probability', 0) * 100
        recommendation = ai_match.get('recommendation', 'CONSIDER')

        # Color code based on recommendation
        if 'APPLY NOW' in recommendation:
