                'ai_match_score': score,
                'ai_success_prob': success,
                'status': 'applied',
                'outcome': 'pending'
            }
            history.append(app_record)
            save_history(history)

            # Record in backend
            res = requests.post(f"{API_URL}/api/apply", json={
                "email": config["email"],
                "job": job
            })

            applied += 1
            print(f"✅ Recorded application\n")
        else:
            print(f"⏭️  Skipped\n")

    print(f"\n✨ Applied to {applied}/{len(jobs)} jobs")
    print(f"📊 ML will learn from your applications to improve future matches!")

def analyze():
    """Analyze application performance"""
    history = load_history()

    if not history:
        print("❌ No application history yet.")
        return

    print("\n" + "="*70)
    print("📊 APPLICATION ANALYTICS")
    print("="*70)

    total = len(history)
    by_status = {}
    by_company = {}
    scores = []

    for app in history:
        status = app.get('status', 'unknown')
        company = app.get('company', 'Unknown')
        score = app.get('ai_match_score', 0)

        by_status[status] = by_status.get(status, 0) + 1
        by_company[company] = by_company.get(company, 0) + 1
        if score > 0:
            scores.append(score)

    print(f"\nTotal Applications: {total}")
    print(f"\nBy Status:")
    for status, count in sorted(by_status.items()):
        pct = count / total * 100
        print(f"  {status}: {count} ({pct:.1f}%)")

    if scores:
        avg_score = sum(scores) / len(scores)
        print(f"\nAverage Match Score: {avg_score:.1f}/100")

    print(f"\nTop Companies:")
    for company, count in sorted(by_company.items(), key=lambda x: x[1], reverse=True)[:5]:
        print(f"  {company}: {count} applications")

    print("\n" + "="*70)

def main():
    if len(sys.argv) < 2:
        print("🤖 applier-ai - AI-Enhanced Job Application Tool")
        print("\nUsage:")
        print("  ./applier-ai setup    - Setup AI profile & resume")
        print("  ./applier-ai search   - AI-powered job search & ranking")
        print("  ./applier-ai apply    - Apply with AI recommendations")
        print("  ./applier-ai analyze  - View application analytics")
        print("  ./applier-ai list     - List applications")
        return

    cmd = sys.argv[1]

    if cmd == "setup":
        setup()
    elif cmd == "search":
        search()
    elif cmd == "apply":
        apply()
    elif cmd == "analyze":
        analyze()
    elif cmd == "list":
        # Same as original
        config = load_config()
        if not config.get("email"):
            print("❌ Not set up. Run: ./applier-ai setup")
            return

        res = requests.get(f"{API_URL}/api/applications?email={config['email']}")
        if res.status_code == 200:
            data = res.json()
            apps = data["applications"]

            print(f"\n📊 Your Applications ({data['total']} total)\n")
            if not apps:
                print("   No applications yet.")
            else:
                for app in apps:
                    print(f"   [{app['status']}] {app['position']} at {app['company']}")
                    print(f"   Platform: {app['platform']} | {app['submitted_at'][:10]}\n")
    else:
        print(f"Unknown command: {cmd}")

if __name__ == "__main__":
    from datetime import datetime
    main()
