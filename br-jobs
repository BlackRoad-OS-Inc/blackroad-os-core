async def main():
    """Main CLI entry point"""

    if not MODULES_AVAILABLE:
        print("❌ Required modules not found")
        print("Run from: /Users/alexa/blackroad-sandbox/")
        return

    args = sys.argv[1:]

    if not args:
        print(__doc__)
        return

    os_system = BRJobsOS()
    command = args[0]

    try:
        if command == "search":
            role = args[1] if len(args) > 1 else "Senior Software Engineer"
            count = int(args[2]) if len(args) > 2 else 20
            auto_apply = "--auto-submit" in args

            await os_system.search(role, count, auto_apply)

        elif command == "track":
            await os_system.track(
                sync_all="--sync-all" in args,
                nudge="--nudge" in args,
                idle_days=7
            )

        elif command == "interview":
            subcommand = args[1] if len(args) > 1 else "prep"
            await os_system.interview(subcommand)

        elif command == "negotiate":
            subcommand = args[1] if len(args) > 1 else "parse"
            await os_system.negotiate(subcommand)

        elif command == "analytics":
            await os_system.analytics(full_funnel="--full-funnel" in args)

        elif command == "setup":
            print("🔧 Running setup...")
            # Run the original CLI for setup
            from applier_cli import setup_profile
            setup_profile()

        else:
            print(f"❌ Unknown command: {command}")
            print(__doc__)

    except Exception as e:
        print(f"❌ Error: {e}")
        import traceback
        traceback.print_exc()


if __name__ == "__main__":
    asyncio.run(main())
