    async def _search_platforms(self, role: str, count: int, strategy: Dict) -> List[Dict]:
        """Search job platforms (mock for now)"""

        # Mock job data - in production, this would call real APIs
        companies = [
            "Stripe", "Anthropic", "Vercel", "Cloudflare", "OpenAI",
            "Railway", "Linear", "Render", "Fly.io", "Supabase",
            "Replit", "Cursor", "Notion", "Figma", "Loom"
        ]

        jobs = []
        for i, company in enumerate(companies[:count]):
            jobs.append({
                "id": f"job_{i+1}",
                "title": role,
                "company": company,
                "match": 95 - (i * 2),
                "salary": f"${150 + i*10}K-{200 + i*15}K",
                "location": "Remote" if i % 2 == 0 else f"{company} HQ / Remote",
                "url": f"https://jobs.lever.co/{company.lower()}/{i+1}"
            })

        return jobs

