    async def search(self, role: str, count: int = 20, auto_apply: bool = False):
        """
        Intelligent job search with AI reasoning

        Steps:
        1. AI analyzes your profile & generates search strategy
        2. Searches 30+ platforms
        3. AI scores each job with reasoning
        4. Generates personalized applications
        5. Optionally auto-submits
        """

        print(f"🔍 Searching for: {role}")
        print(f"📊 Target: {count} applications")

        # Load profile
        profile_path = Path.home() / '.applier' / 'profile.json'
        if not profile_path.exists():
            print("❌ No profile found. Run: br-jobs setup")
            return

        with open(profile_path) as f:
            profile = json.load(f)

        # Generate AI search strategy
        if self.reasoning:
            print("\n🧠 AI is analyzing your search...")
            strategy = self.reasoning.generate_search_strategy(role, profile)

            print(f"Strategy: {strategy.get('priority', 'balanced')}")
            if strategy.get('target_companies'):
                print(f"Targeting: {', '.join(strategy['target_companies'][:5])}")

        # Search platforms (simplified for demo)
        jobs = await self._search_platforms(role, count, strategy if self.reasoning else {})

        # AI match scoring
        if self.reasoning:
            print("\n🧠 AI is scoring job matches...")
            for job in jobs:
                analysis = self.reasoning.match_job_to_user(job, profile)
                job['match'] = analysis.get('match_score', job.get('match', 80))
                job['ai_reasoning'] = analysis.get('reasoning', '')
                job['ai_recommendation'] = analysis.get('recommendation', 'apply')

        # Sort by match
        jobs = sorted(jobs, key=lambda x: x.get('match', 0), reverse=True)

        # Show top matches
        print(f"\n✅ Found {len(jobs)} jobs\n")
        print("🏆 Top Matches:\n")

        for i, job in enumerate(jobs[:10], 1):
            match = job.get('match', 0)
            emoji = "🟢" if match >= 85 else "🟡" if match >= 75 else "🔴"
            print(f"{i}. {emoji} {job['company']} - {job['title']} ({match}%)")
            print(f"   {job.get('salary', 'N/A')} • {job.get('location', 'N/A')}")
            if job.get('ai_recommendation') == 'skip':
                print(f"   ⚠️  AI recommends skipping")
            print()

        # Generate applications
        print("\n📝 Generating AI-powered applications...")

        for job in jobs[:count]:
            if self.reasoning and job.get('ai_recommendation') == 'skip':
                print(f"⏭️  Skipping {job['company']} (AI recommendation)")
                continue

            # Generate cover letter
            if self.reasoning:
                cover_letter = self.reasoning.generate_cover_letter(job, profile)
                job['cover_letter'] = cover_letter

            print(f"✅ {job['company']} - Application ready")

        # Auto-submit if requested
        if auto_apply:
            print("\n🤖 Auto-submitting applications...")
            await self._auto_submit_all(jobs[:count], profile)

        return {
            "status": "success",
            "jobs_found": len(jobs),
            "applications_generated": count,
            "auto_submitted": auto_apply
        }

    async def track(self, sync_all: bool = False, nudge: bool = False,
                   idle_days: int = 7):
        """
        Track all applications & sync status

        Features:
        - Syncs status from ATS APIs
        - Auto-nudge for stale applications
        - Stage change notifications
        """

        print("📊 Application Tracking\n")

        if sync_all:
            print("🔄 Syncing all applications with ATS...")
            result = await self.tracker.sync()

            print(f"✅ Synced {result['synced_count']} applications")

            if result['updated_count'] > 0:
                print(f"🔔 {result['updated_count']} status updates:")
                for update in result['updates']:
                    print(f"  • {update['company']}: {update['old_stage']} → {update['new_stage']}")

        if nudge:
            print(f"\n📧 Nudging applications idle >{idle_days} days...")
            result = await self.tracker.nudge(idle_days=idle_days, dry_run=False)

            print(f"✅ Sent {result['nudged_count']} follow-ups")

        # Show analytics
        analytics = self.tracker.analytics()

        print("\n📈 Current Status:")
        print(f"Total Applications: {analytics['total_applications']}")
        print(f"\nFunnel:")
        for stage, count in analytics['funnel'].items():
            print(f"  {stage}: {count}")

        if analytics.get('conversion_rates'):
            print(f"\nConversion Rates:")
            for metric, rate in analytics['conversion_rates'].items():
                print(f"  {metric}: {rate}%")

